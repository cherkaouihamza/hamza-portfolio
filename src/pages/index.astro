---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <!-- ═══════════════════════════════════════════
       NAVIGATION
  ═══════════════════════════════════════════ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-forest/95 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-18">

        <!-- Logo -->
        <a href="#hero" class="flex items-center gap-3 group">
          <div class="relative">
            <span class="text-2xl font-black tracking-wider gradient-text select-none">HCH</span>
            <span class="absolute -bottom-0.5 left-0 w-full h-px bg-gold/30"></span>
          </div>
          <span class="hidden sm:block text-white/60 text-sm font-light tracking-widest uppercase">Hamza Cherkaoui</span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-8">
          <a href="#valeur"       class="nav-link text-white/80 text-sm font-medium">Valeur</a>
          <a href="#expertise"    class="nav-link text-white/80 text-sm font-medium">Expertise</a>
          <a href="#services"     class="nav-link text-white/80 text-sm font-medium">Services</a>
          <a href="#cas"          class="nav-link text-white/80 text-sm font-medium">Cas clients</a>
          <a href="#certifications" class="nav-link text-white/80 text-sm font-medium">Certifications</a>
          <a
            href="#contact"
            class="ml-2 px-5 py-2 bg-gold text-forest text-sm font-semibold rounded-sm hover:bg-gold-light transition-colors duration-200"
          >
            Contact
          </a>
        </div>

        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="md:hidden p-2 text-white/80 hover:text-gold transition-colors"
          aria-label="Menu"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-forest-dark border-t border-white/10">
      <div class="px-6 py-4 flex flex-col gap-4">
        <a href="#valeur"         class="text-white/80 text-sm font-medium hover:text-gold transition-colors">Valeur</a>
        <a href="#expertise"      class="text-white/80 text-sm font-medium hover:text-gold transition-colors">Expertise</a>
        <a href="#services"       class="text-white/80 text-sm font-medium hover:text-gold transition-colors">Services</a>
        <a href="#cas"            class="text-white/80 text-sm font-medium hover:text-gold transition-colors">Cas clients</a>
        <a href="#certifications" class="text-white/80 text-sm font-medium hover:text-gold transition-colors">Certifications</a>
        <a href="#contact" class="inline-block px-5 py-2.5 bg-gold text-forest text-sm font-semibold rounded-sm text-center">
          Contact
        </a>
      </div>
    </div>
  </nav>


  <!-- ═══════════════════════════════════════════
       1. HERO
  ═══════════════════════════════════════════ -->
  <section
    id="hero"
    class="relative min-h-screen flex items-center justify-center bg-forest overflow-hidden"
    style="background: radial-gradient(ellipse at 30% 60%, #254d45 0%, #1a3a35 55%, #122926 100%);"
  >
    <!-- Decorative elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 right-10 w-72 h-72 rounded-full bg-gold/5 blur-3xl"></div>
      <div class="absolute bottom-1/3 left-10 w-96 h-96 rounded-full bg-gold/3 blur-3xl"></div>
      <!-- Grid pattern -->
      <div
        class="absolute inset-0 opacity-[0.025]"
        style="background-image: linear-gradient(#c9a96e 1px, transparent 1px), linear-gradient(90deg, #c9a96e 1px, transparent 1px); background-size: 60px 60px;"
      ></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center py-32">
      <!-- HCH Monogram -->
      <div class="mb-8 reveal">
        <div class="inline-block relative">
          <span
            class="text-7xl md:text-8xl lg:text-9xl font-black tracking-wider gradient-text leading-none"
            style="text-shadow: 0 0 80px rgba(201, 169, 110, 0.2);"
          >HCH</span>
          <div class="absolute -inset-3 rounded-sm border border-gold/20"></div>
        </div>
      </div>

      <!-- Name -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-wide reveal reveal-delay-1">
        Hamza Cherkaoui
      </h1>

      <!-- Title -->
      <p class="text-gold text-sm md:text-base font-medium tracking-[0.25em] uppercase mb-8 reveal reveal-delay-2">
        Consultant &nbsp;·&nbsp; Formateur &nbsp;·&nbsp; PMO &nbsp;·&nbsp; Expert en Transformation Digitale
      </p>

      <!-- Tagline -->
      <p class="text-white/70 text-lg md:text-xl lg:text-2xl font-light max-w-2xl mx-auto mb-12 leading-relaxed reveal reveal-delay-3">
        Accélérateur de performance organisationnelle —
        <span class="text-white font-normal">de la stratégie à l'exécution</span>
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-4">
        <a
          href="#contact"
          class="px-8 py-4 bg-gold text-forest font-semibold text-sm tracking-wide uppercase hover:bg-gold-light transition-all duration-200 rounded-sm shadow-lg shadow-gold/20 hover:shadow-gold/30 hover:shadow-xl"
        >
          Prendre rendez-vous
        </a>
        <a
          href="#valeur"
          class="px-8 py-4 border border-white/25 text-white font-medium text-sm tracking-wide hover:border-gold/60 hover:text-gold transition-all duration-200 rounded-sm"
        >
          Découvrir mon approche
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 reveal reveal-delay-4">
        <div class="flex flex-col items-center gap-2 text-white/30">
          <span class="text-xs tracking-widest uppercase">Défiler</span>
          <div class="w-px h-10 bg-gradient-to-b from-white/30 to-transparent animate-pulse"></div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       2. PROPOSITION DE VALEUR
  ═══════════════════════════════════════════ -->
  <section id="valeur" class="py-24 lg:py-32 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16 reveal">
        <span class="text-gold text-xs font-semibold tracking-[0.3em] uppercase mb-4 block">Pourquoi me choisir</span>
        <h2 class="text-3xl md:text-4xl font-bold text-forest gold-underline gold-underline-center inline-block pb-4">
          Ma proposition de valeur
        </h2>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <!-- Card 1 -->
        <div class="card-hover reveal reveal-delay-1 bg-white rounded-sm p-8 border border-gray-100 shadow-sm group">
          <div class="w-12 h-12 bg-forest/5 rounded-sm flex items-center justify-center mb-6 group-hover:bg-forest/10 transition-colors">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
            </svg>
          </div>
          <h3 class="text-forest text-xl font-bold mb-2">Stratégie → Exécution</h3>
          <div class="w-8 h-0.5 bg-gold mb-4"></div>
          <p class="text-gray-500 leading-relaxed">
            Des feuilles de route opérationnelles, pas théoriques. Chaque mission se traduit en plans d'action concrets, activables dès J+1.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="card-hover reveal reveal-delay-2 bg-forest rounded-sm p-8 shadow-lg group relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gold/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <div class="w-12 h-12 bg-white/10 rounded-sm flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-white text-xl font-bold mb-2">Impact Mesurable</h3>
          <div class="w-8 h-0.5 bg-gold mb-4"></div>
          <p class="text-white/65 leading-relaxed">
            KPIs définis dès le départ, résultats trackés à chaque étape. Vous savez exactement où vous en êtes et ce qui a été accompli.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="card-hover reveal reveal-delay-3 bg-white rounded-sm p-8 border border-gray-100 shadow-sm group">
          <div class="w-12 h-12 bg-forest/5 rounded-sm flex items-center justify-center mb-6 group-hover:bg-forest/10 transition-colors">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <h3 class="text-forest text-xl font-bold mb-2">Transfert de Compétences</h3>
          <div class="w-8 h-0.5 bg-gold mb-4"></div>
          <p class="text-gray-500 leading-relaxed">
            Vos équipes autonomes à l'issue de chaque mission. L'objectif n'est pas de créer une dépendance, mais de vous rendre indépendants.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       3. CHIFFRES CLÉS
  ═══════════════════════════════════════════ -->
  <section id="chiffres" class="py-24 bg-forest relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-gold/5 blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-gold/5 blur-3xl"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16 reveal">
        <span class="text-gold/70 text-xs font-semibold tracking-[0.3em] uppercase mb-4 block">En chiffres</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white">Une expertise qui se mesure</h2>
      </div>

      <!-- Stats grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4">
        <div class="text-center reveal reveal-delay-1 group">
          <div class="text-6xl md:text-7xl font-black gradient-text leading-none mb-2">50<span class="text-gold">+</span></div>
          <div class="w-8 h-px bg-gold/40 mx-auto mb-3"></div>
          <div class="text-white/70 text-sm font-medium tracking-wide uppercase">Projets menés</div>
        </div>
        <div class="text-center reveal reveal-delay-2 group">
          <div class="text-6xl md:text-7xl font-black gradient-text leading-none mb-2">12<span class="text-gold">+</span></div>
          <div class="w-8 h-px bg-gold/40 mx-auto mb-3"></div>
          <div class="text-white/70 text-sm font-medium tracking-wide uppercase">Années d'expérience</div>
        </div>
        <div class="text-center reveal reveal-delay-3 group">
          <div class="text-6xl md:text-7xl font-black gradient-text leading-none mb-2">300<span class="text-gold">+</span></div>
          <div class="w-8 h-px bg-gold/40 mx-auto mb-3"></div>
          <div class="text-white/70 text-sm font-medium tracking-wide uppercase">Professionnels formés</div>
        </div>
        <div class="text-center reveal reveal-delay-4 group">
          <div class="text-6xl md:text-7xl font-black gradient-text leading-none mb-2">20<span class="text-gold">+</span></div>
          <div class="w-8 h-px bg-gold/40 mx-auto mb-3"></div>
          <div class="text-white/70 text-sm font-medium tracking-wide uppercase">Missions réalisées</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       4. EXPERTISE — 5 PILIERS
  ═══════════════════════════════════════════ -->
  <section id="expertise" class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16 reveal">
        <span class="text-gold text-xs font-semibold tracking-[0.3em] uppercase mb-4 block">Domaines d'intervention</span>
        <h2 class="text-3xl md:text-4xl font-bold text-forest gold-underline gold-underline-center inline-block pb-4">
          5 piliers d'expertise
        </h2>
      </div>

      <!-- Pillars grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Pilier 1 -->
        <div class="card-hover reveal reveal-delay-1 relative bg-cream rounded-sm p-8 border border-gray-100 overflow-hidden group lg:col-span-1">
          <div class="absolute top-4 right-4 text-7xl font-black text-forest/5 leading-none select-none group-hover:text-forest/8 transition-colors">01</div>
          <div class="w-10 h-10 bg-forest rounded-sm flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
            </svg>
          </div>
          <h3 class="text-forest font-bold text-lg mb-2">Gestion de Projet & PMO</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Pilotage de projets complexes, mise en place de bureaux de projet, gouvernance et reporting stratégique.
          </p>
        </div>

        <!-- Pilier 2 -->
        <div class="card-hover reveal reveal-delay-2 relative bg-cream rounded-sm p-8 border border-gray-100 overflow-hidden group">
          <div class="absolute top-4 right-4 text-7xl font-black text-forest/5 leading-none select-none group-hover:text-forest/8 transition-colors">02</div>
          <div class="w-10 h-10 bg-forest rounded-sm flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-forest font-bold text-lg mb-2">Transformation Digitale</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Conduite du changement, digitalisation des processus et déploiement de solutions numériques à fort impact.
          </p>
        </div>

        <!-- Pilier 3 -->
        <div class="card-hover reveal reveal-delay-3 relative bg-cream rounded-sm p-8 border border-gray-100 overflow-hidden group">
          <div class="absolute top-4 right-4 text-7xl font-black text-forest/5 leading-none select-none group-hover:text-forest/8 transition-colors">03</div>
          <div class="w-10 h-10 bg-forest rounded-sm flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-forest font-bold text-lg mb-2">IA pour les Affaires</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Intégration de l'intelligence artificielle dans les processus métier, formation et accompagnement pratique.
          </p>
        </div>

        <!-- Pilier 4 -->
        <div class="card-hover reveal reveal-delay-1 relative bg-cream rounded-sm p-8 border border-gray-100 overflow-hidden group">
          <div class="absolute top-4 right-4 text-7xl font-black text-forest/5 leading-none select-none group-hover:text-forest/8 transition-colors">04</div>
          <div class="w-10 h-10 bg-forest rounded-sm flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-forest font-bold text-lg mb-2">Gestion des Risques & Qualité</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Identification, évaluation et mitigation des risques. Démarches qualité et amélioration continue.
          </p>
        </div>

        <!-- Pilier 5 -->
        <div class="card-hover reveal reveal-delay-2 relative bg-cream rounded-sm p-8 border border-gray-100 overflow-hidden group sm:col-span-2 lg:col-span-2">
          <div class="absolute top-4 right-4 text-7xl font-black text-forest/5 leading-none select-none group-hover:text-forest/8 transition-colors">05</div>
          <div class="w-10 h-10 bg-forest rounded-sm flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="text-forest font-bold text-lg mb-2">Communication Professionnelle</h3>
          <p class="text-gray-500 text-sm leading-relaxed">
            Communication stratégique, facilitation d'ateliers, présentations exécutives et alignement des parties prenantes autour d'une vision commune.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       5. SERVICES
  ═══════════════════════════════════════════ -->
  <section id="services" class="py-24 lg:py-32 bg-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16 reveal">
        <span class="text-gold text-xs font-semibold tracking-[0.3em] uppercase mb-4 block">Ce que je propose</span>
        <h2 class="text-3xl md:text-4xl font-bold text-forest gold-underline gold-underline-center inline-block pb-4">
          Services
        </h2>
      </div>

      <!-- Services grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Service 1 -->
        <div class="card-hover reveal reveal-delay-1 bg-white rounded-sm p-8 border border-gray-100 shadow-sm group">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-11 h-11 bg-forest rounded-sm flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-forest text-xl font-bold">IA & Productivité</h3>
          </div>
          <ul class="space-y-3">
            {[
              "Formation à l'usage de l'IA en entreprise",
              "Automatisation des tâches répétitives",
              "Déploiement d'outils IA métier (ChatGPT, Copilot…)",
              "Audit et stratégie d'adoption de l'IA",
              "Ateliers pratiques et accompagnement des équipes",
            ].map(item => (
              <li class="flex items-start gap-3 text-gray-600 text-sm">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-gold flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Service 2 -->
        <div class="card-hover reveal reveal-delay-2 bg-white rounded-sm p-8 border border-gray-100 shadow-sm group">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-11 h-11 bg-forest rounded-sm flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <h3 class="text-forest text-xl font-bold">Gestion de Projet Opérationnelle</h3>
          </div>
          <ul class="space-y-3">
            {[
              "Pilotage de projets complexes (IT, RH, Finance…)",
              "Planification et suivi de jalons critiques",
              "Gestion des risques et des dépendances",
              "Reporting et dashboards de performance",
              "Formation des chefs de projet internes",
            ].map(item => (
              <li class="flex items-start gap-3 text-gray-600 text-sm">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-gold flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Service 3 -->
        <div class="card-hover reveal reveal-delay-3 bg-white rounded-sm p-8 border border-gray-100 shadow-sm group">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-11 h-11 bg-forest rounded-sm flex items-center justify-center flex-shrink-0">
