---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Hamza Cherkaoui — Formateur Expert en Management de Projet, PMO & IA"
  description="J'accompagne les entreprises et les professionnels à monter en compétences sur la gestion de projet, la gouvernance PMO et l'intégration de l'IA."
>

  <!-- ════════════════════════════════════════
       HERO
  ════════════════════════════════════════ -->
  <section class="bg-[#1a3a35] text-white pt-0 pb-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

        <!-- LEFT: text (order-2 on mobile so photo appears first) -->
        <div class="order-2 md:order-1 flex-1 flex flex-col gap-6 text-center md:text-left items-center md:items-start">

          <!-- Name -->
          <p class="text-xl md:text-2xl text-[#c9a96e] font-light tracking-widest mb-1">
            Hamza CHERKAOUI
          </p>

          <!-- Eyebrow -->
          <p class="text-[#c9a96e] text-xs font-bold uppercase tracking-[0.2em]">
            From Governance to Performance, Powered by Technology
          </p>

          <!-- Headline -->
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1]">
            Formateur Expert en<br />
            Management de Projet,<br />
            <span class="text-[#c9a96e]">PMO &amp; IA</span>
          </h1>

          <!-- Description -->
          <p class="text-white/70 text-lg leading-relaxed max-w-xl">
            J'accompagne les entreprises et les professionnels à monter en compétences
            sur la gestion de projet, la gouvernance PMO et l'intégration de l'IA —
            avec des formations <strong class="text-white font-semibold">100% pratiques</strong>
            et orientées résultats.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <a
              href="https://calendly.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-[#c9a96e] hover:bg-[#d4b87e] text-[#122926] font-semibold px-8 py-4 rounded-xl transition-colors duration-200 shadow-lg shadow-black/20"
            >
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
              </svg>
              Réserver une session
            </a>
            <a
              href="/formations"
              class="inline-flex items-center justify-center border border-white/25 hover:border-[#c9a96e] hover:text-[#c9a96e] text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200"
            >
              Découvrir les formations
              <svg class="ml-2" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

        </div>

        <!-- RIGHT: photo (order-1 on mobile so it appears on top) -->
        <div class="order-1 md:order-2 flex-shrink-0">
          <!-- Outer wrapper: holds the gold glow ring -->
          <div class="relative">
            <div class="absolute -inset-1 rounded-2xl bg-gradient-to-br from-[#c9a96e] to-[#d4b87e] opacity-35 blur-sm"></div>
            <!-- Inner wrapper: overflow-hidden clips the gradient overlays to the rounded frame -->
            <div class="relative w-64 h-80 md:w-80 md:h-[520px] rounded-2xl overflow-hidden border-4 border-[#c9a96e]/40 shadow-2xl">
              <img
                src="/photo-hamza.jpg.JPG"
                alt="Hamza Cherkaoui"
                class="w-full h-full object-cover object-top"
              />
              <!-- Right-side vignette: fades out background content -->
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-[#1a3a35]/80"></div>
              <!-- Bottom vignette: softens lower edge -->
              <div class="absolute inset-0 bg-gradient-to-t from-[#1a3a35]/60 via-transparent to-transparent"></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       STATS
  ════════════════════════════════════════ -->
  <section class="bg-white border-b border-[#E2E8F0]">
    <div class="max-w-3xl mx-auto px-6 py-16 grid grid-cols-3 gap-6 text-center">

      <div class="reveal flex flex-col items-center gap-1">
        <p class="text-4xl md:text-5xl font-bold text-[#1a3a35]">4</p>
        <p class="text-sm text-[#64748B] font-medium leading-snug">Domaines de<br/>formation</p>
      </div>

      <div class="reveal reveal-delay-1 flex flex-col items-center gap-1 border-x border-[#E2E8F0]">
        <p class="text-4xl md:text-5xl font-bold text-[#1a3a35]">100%</p>
        <p class="text-sm text-[#64748B] font-medium leading-snug">Pratique</p>
      </div>

      <div class="reveal reveal-delay-2 flex flex-col items-center gap-1">
        <p class="text-4xl md:text-5xl font-bold text-[#1a3a35]">2</p>
        <p class="text-sm text-[#64748B] font-medium leading-snug">Études de<br/>cas réels</p>
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════
       TRAINING CARDS
  ════════════════════════════════════════ -->
  <section class="bg-[#F8FAFC] py-24 px-6">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold tracking-tight text-[#1a3a35] mb-3 reveal">Mes Formations</h2>
        <p class="text-[#64748B] max-w-xl mx-auto reveal reveal-delay-1">
          Des programmes conçus pour un impact immédiat dans votre organisation.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <!-- Card 1 — PM Fundamentals -->
        <div class="bg-white rounded-2xl border border-[#E2E8F0] p-6 flex flex-col card-hover reveal">
          <div class="w-10 h-10 rounded-xl bg-[#c9a96e]/10 flex items-center justify-center mb-5">
            <svg width="20" height="20" fill="none" stroke="#c9a96e" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="1"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <span class="text-[11px] font-bold uppercase tracking-widest text-emerald-500 mb-2">Débutant</span>
          <h3 class="text-base font-bold text-[#1a3a35] leading-snug mb-3">Project Management Fundamentals</h3>
          <p class="text-sm text-[#64748B] flex items-center gap-1.5">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            2–3 jours
          </p>
          <div class="mt-auto pt-5 border-t border-[#E2E8F0]">
            <a href="/formations" class="text-sm font-semibold text-[#c9a96e] hover:text-[#d4b87e] transition-colors inline-flex items-center gap-1">
              En savoir plus
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Card 2 — Advanced PM -->
        <div class="bg-white rounded-2xl border border-[#E2E8F0] p-6 flex flex-col card-hover reveal reveal-delay-1">
          <div class="w-10 h-10 rounded-xl bg-[#c9a96e]/10 flex items-center justify-center mb-5">
            <svg width="20" height="20" fill="none" stroke="#c9a96e" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
              <polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
          <span class="text-[11px] font-bold uppercase tracking-widest text-orange-500 mb-2">Avancé</span>
          <h3 class="text-base font-bold text-[#1a3a35] leading-snug mb-3">Advanced Project Management</h3>
          <p class="text-sm text-[#64748B] flex items-center gap-1.5">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            3 jours
          </p>
          <div class="mt-auto pt-5 border-t border-[#E2E8F0]">
            <a href="/formations" class="text-sm font-semibold text-[#c9a96e] hover:text-[#d4b87e] transition-colors inline-flex items-center gap-1">
              En savoir plus
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Card 3 — AI Integration -->
        <div class="bg-white rounded-2xl border border-[#E2E8F0] p-6 flex flex-col card-hover reveal reveal-delay-2">
          <div class="w-10 h-10 rounded-xl bg-[#c9a96e]/10 flex items-center justify-center mb-5">
            <svg width="20" height="20" fill="none" stroke="#c9a96e" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73A2 2 0 0 1 10 4a2 2 0 0 1 2-2z"/>
              <circle cx="7.5" cy="14.5" r="1.5" fill="#c9a96e" stroke="none"/>
              <circle cx="16.5" cy="14.5" r="1.5" fill="#c9a96e" stroke="none"/>
            </svg>
          </div>
          <span class="text-[11px] font-bold uppercase tracking-widest text-violet-500 mb-2">Tous niveaux</span>
          <h3 class="text-base font-bold text-[#1a3a35] leading-snug mb-3">AI Integration for Business</h3>
          <p class="text-sm text-[#64748B] flex items-center gap-1.5">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            2 jours
          </p>
          <div class="mt-auto pt-5 border-t border-[#E2E8F0]">
            <a href="/formations" class="text-sm font-semibold text-[#c9a96e] hover:text-[#d4b87e] transition-colors inline-flex items-center gap-1">
              En savoir plus
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Card 4 — PMO Excellence -->
        <div class="bg-white rounded-2xl border border-[#E2E8F0] p-6 flex flex-col card-hover reveal reveal-delay-3">
          <div class="w-10 h-10 rounded-xl bg-[#c9a96e]/10 flex items-center justify-center mb-5">
            <svg width="20" height="20" fill="none" stroke="#c9a96e" stroke-width="2" viewBox="0 0 24 24">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <span class="text-[11px] font-bold uppercase tracking-widest text-orange-500 mb-2">Avancé</span>
          <h3 class="text-base font-bold text-[#1a3a35] leading-snug mb-3">PMO Excellence</h3>
          <p class="text-sm text-[#64748B] flex items-center gap-1.5">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            2–3 jours
          </p>
          <div class="mt-auto pt-5 border-t border-[#E2E8F0]">
            <a href="/formations" class="text-sm font-semibold text-[#c9a96e] hover:text-[#d4b87e] transition-colors inline-flex items-center gap-1">
              En savoir plus
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       TESTIMONIALS
  ════════════════════════════════════════ -->
  <section class="bg-white py-24 px-6">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold tracking-tight text-[#1a3a35] mb-3 reveal">Ce que disent mes clients</h2>
        <p class="text-[#64748B] reveal reveal-delay-1">Des résultats concrets, validés par des professionnels.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- T1 -->
        <div class="bg-[#F8FAFC] rounded-2xl border border-[#E2E8F0] p-8 flex flex-col gap-5 reveal">
          <div class="flex gap-0.5">
            {[...Array(5)].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#F59E0B">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <p class="text-[#1a3a35] leading-relaxed italic text-sm flex-1">
            "La formation sur le Management de Projet a transformé notre façon de piloter les initiatives.
            L'approche pratique, basée sur des cas réels, nous a permis d'appliquer les concepts dès le lendemain."
          </p>
          <div class="pt-4 border-t border-[#E2E8F0]">
            <p class="font-semibold text-[#1a3a35] text-sm">Responsable IT</p>
            <p class="text-[#64748B] text-xs mt-0.5">Industrie Pharmaceutique</p>
          </div>
        </div>

        <!-- T2 -->
        <div class="bg-[#F8FAFC] rounded-2xl border border-[#E2E8F0] p-8 flex flex-col gap-5 reveal reveal-delay-1">
          <div class="flex gap-0.5">
            {[...Array(5)].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#F59E0B">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <p class="text-[#1a3a35] leading-relaxed italic text-sm flex-1">
            "Hamza a su adapter le contenu de la formation PMO Excellence à notre contexte spécifique.
            Son expertise et sa pédagogie claire nous ont fourni des outils directement actionnables
            pour structurer notre bureau de projets."
          </p>
          <div class="pt-4 border-t border-[#E2E8F0]">
            <p class="font-semibold text-[#1a3a35] text-sm">Directeur de Projets</p>
            <p class="text-[#64748B] text-xs mt-0.5">Secteur Bancaire & Financier</p>
          </div>
        </div>

        <!-- T3 -->
        <div class="bg-[#F8FAFC] rounded-2xl border border-[#E2E8F0] p-8 flex flex-col gap-5 reveal reveal-delay-2">
          <div class="flex gap-0.5">
            {[...Array(5)].map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#F59E0B">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <p class="text-[#1a3a35] leading-relaxed italic text-sm flex-1">
            "La formation sur l'intégration de l'IA en entreprise a ouvert de nouvelles perspectives pour
            notre équipe. Concrète, structurée et tournée vers l'action — exactement ce qu'il nous fallait
            pour passer à l'étape suivante."
          </p>
          <div class="pt-4 border-t border-[#E2E8F0]">
            <p class="font-semibold text-[#1a3a35] text-sm">Chef de Projet Digital</p>
            <p class="text-[#64748B] text-xs mt-0.5">Télécommunications</p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       BOTTOM CTA
  ════════════════════════════════════════ -->
  <section class="bg-[#122926] py-24 px-6">
    <div class="max-w-2xl mx-auto text-center flex flex-col items-center gap-6 reveal">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white leading-tight">
        Prêt à former vos équipes ?
      </h2>
      <p class="text-white/60 text-lg">
        Contactez-moi pour un programme sur mesure.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 bg-[#c9a96e] hover:bg-[#d4b87e] text-[#122926] font-semibold px-10 py-4 rounded-xl transition-colors duration-200 shadow-lg shadow-black/20"
      >
        Prendre contact
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

</Layout>


<script>
  // Scroll-reveal via IntersectionObserver
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
