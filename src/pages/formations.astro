---
import Layout from '../layouts/Layout.astro';

const formations = [
  {
    id: 1,
    icon: `<svg width="28" height="28" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
      <rect x="9" y="3" width="6" height="4" rx="1"/>
      <path d="m9 12 2 2 4-4"/>
    </svg>`,
    level: "Débutant",
    levelColor: "text-[#c9a96e] bg-[#c9a96e]/15",
    title: "Project Management Fundamentals",
    audience: "Chefs de projet juniors, professionnels tous secteurs",
    duration: "2 à 3 jours — Présentiel ou distanciel",
    description: "Introduction complète au management de projet couvrant tous les domaines de connaissance basés sur les standards PMP et PRINCE2. Une base solide pour piloter vos projets avec méthode et confiance.",
    features: [
      "60–70% ateliers pratiques",
      "Focus fort sur les méthodologies Agile",
      "Exercices sur cas réels d'entreprise",
      "Templates et outils inclus",
    ],
    outcomes: [
      "Maîtriser le cycle de vie complet d'un projet",
      "Appliquer les outils immédiatement en poste",
      "Gagner en autonomie opérationnelle",
    ],
  },
  {
    id: 2,
    icon: `<svg width="28" height="28" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
      <polyline points="16 7 22 7 22 13"/>
    </svg>`,
    level: "Avancé",
    levelColor: "text-[#c9a96e] bg-[#c9a96e]/15",
    title: "Advanced Project Management",
    audience: "Chefs de projet seniors, managers de programmes",
    duration: "3 jours — Présentiel ou distanciel",
    description: "Formation avancée axée sur la gestion de programmes et de portefeuilles avec un fort accent sur l'alignement stratégique. Pensée pour les profils expérimentés qui veulent élever leur niveau de gouvernance.",
    features: [
      "Gestion de programmes et portefeuilles",
      "Alignement stratégique des projets",
      "Gouvernance avancée et reporting",
      "Frameworks avancés (MSP, MoP)",
    ],
    outcomes: [
      "Gérer des programmes complexes et multi-projets",
      "Améliorer la prise de décision stratégique",
    ],
  },
  {
    id: 3,
    icon: `<svg width="28" height="28" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73A2 2 0 0 1 10 4a2 2 0 0 1 2-2z"/>
      <circle cx="7.5" cy="14.5" r="1.5" fill="#c9a96e" stroke="none"/>
      <circle cx="16.5" cy="14.5" r="1.5" fill="#c9a96e" stroke="none"/>
    </svg>`,
    level: "Tous niveaux",
    levelColor: "text-[#c9a96e] bg-[#c9a96e]/15",
    title: "AI Integration for Business",
    audience: "Tous les collaborateurs (transversal)",
    duration: "2 jours — Présentiel ou distanciel",
    description: "Formation conçue pour aider les entreprises à intégrer l'IA dans leurs opérations quotidiennes. Accessible à tous les profils, avec une approche résolument pratique et orientée usage métier.",
    features: [
      "Fondamentaux de l'IA appliquée",
      "Découverte de 30+ outils IA",
      "Ateliers pratiques sur ~10 outils clés",
      "IA conversationnelle, automatisation & agents IA",
    ],
    outcomes: [
      "Utilisation immédiate des outils dès la fin de la formation",
      "Gain de productivité mesurable dès la première semaine",
    ],
  },
  {
    id: 4,
    icon: `<svg width="28" height="28" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>`,
    level: "Avancé",
    levelColor: "text-[#c9a96e] bg-[#c9a96e]/15",
    title: "PMO Excellence",
    audience: "Équipes PMO, responsables gouvernance",
    duration: "2 à 3 jours — Présentiel ou distanciel",
    description: "Formation PMO avancée axée sur la gouvernance, la performance et la standardisation des pratiques projet. Idéale pour structurer ou faire évoluer un bureau de projets existant.",
    features: [
      "Frameworks de gouvernance PMO",
      "Priorisation et gestion de portefeuille",
      "Conception de tableaux de bord de performance",
      "Gestion des risques et standardisation",
    ],
    outcomes: [
      "PMO structuré, performant et reconnu",
      "Meilleur reporting et prise de décision",
      "Efficacité opérationnelle accrue",
    ],
  },
];
---

<Layout
  title="Mes Formations — Hamza Cherkaoui"
  description="Formations en management de projet, PMO et IA — 100% pratiques, adaptées à vos besoins."
>

  <!-- ════════════════════════════════════════
       PAGE HERO
  ════════════════════════════════════════ -->
  <section class="bg-[#1a3a35] text-white pt-16 pb-20 px-6">
    <div class="max-w-3xl mx-auto text-center flex flex-col items-center gap-5">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight">
        Mes Formations
      </h1>
      <p class="text-white/70 text-lg leading-relaxed max-w-xl">
        Des programmes 100% pratiques, adaptés à vos besoins et orientés résultats.
      </p>
      <!-- Gold divider -->
      <div class="w-16 h-[3px] rounded-full bg-[#c9a96e] mt-1"></div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       TRAINING CARDS
  ════════════════════════════════════════ -->
  <section class="bg-[#f8f8f6] py-20 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8">

      {formations.map((f, i) => (
        <div class={`bg-white rounded-2xl border border-[#E2E8F0] p-8 flex flex-col gap-6 card-hover hover:border-[#c9a96e] transition-colors duration-300 reveal${i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : i === 3 ? ' reveal-delay-3' : ''}`}>

          <!-- Card header -->
          <div class="flex items-start justify-between gap-4">
            <!-- Icon -->
            <div class="w-14 h-14 rounded-xl bg-[#c9a96e]/10 flex items-center justify-center flex-shrink-0">
              <Fragment set:html={f.icon} />
            </div>
            <!-- Level badge -->
            <span class={`text-[11px] font-bold uppercase tracking-widest px-3 py-1 rounded-full ${f.levelColor}`}>
              {f.level}
            </span>
          </div>

          <!-- Title -->
          <div>
            <h2 class="text-xl font-bold text-[#1a3a35] leading-snug mb-3">{f.title}</h2>
            <!-- Meta: audience + duration -->
            <div class="flex flex-col gap-1.5 text-sm text-[#64748B]">
              <p class="flex items-center gap-2">
                <svg width="14" height="14" fill="none" stroke="#c9a96e" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                {f.audience}
              </p>
              <p class="flex items-center gap-2">
                <svg width="14" height="14" fill="none" stroke="#c9a96e" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                </svg>
                {f.duration}
              </p>
            </div>
          </div>

          <!-- Description -->
          <p class="text-[#64748B] text-sm leading-relaxed">{f.description}</p>

          <!-- Divider -->
          <div class="border-t border-[#E2E8F0]"></div>

          <!-- Features -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-[#1a3a35] mb-3">Programme</p>
            <ul class="flex flex-col gap-2">
              {f.features.map(feat => (
                <li class="flex items-start gap-2 text-sm text-[#64748B]">
                  <svg class="flex-shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a96e" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>
          </div>

          <!-- Outcomes -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-[#1a3a35] mb-3">À l'issue de la formation</p>
            <ul class="flex flex-col gap-2">
              {f.outcomes.map(out => (
                <li class="flex items-start gap-2 text-sm text-[#64748B]">
                  <svg class="flex-shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c9a96e" stroke-width="2.5">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                  {out}
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA -->
          <div class="mt-auto pt-2">
            <a
              href="/contact"
              class="inline-flex items-center justify-center w-full gap-2 bg-[#1a3a35] hover:bg-[#122926] text-white font-semibold px-6 py-3.5 rounded-xl transition-colors duration-200"
            >
              Demander un devis
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

        </div>
      ))}

    </div>
  </section>


  <!-- ════════════════════════════════════════
       BOTTOM CTA
  ════════════════════════════════════════ -->
  <section class="bg-[#122926] py-20 px-6">
    <div class="max-w-2xl mx-auto text-center flex flex-col items-center gap-6 reveal">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white leading-snug">
        Vous ne trouvez pas ce que vous cherchez ?
      </h2>
      <p class="text-white/60 text-lg">
        Je conçois également des formations sur mesure adaptées à vos besoins spécifiques.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-[#c9a96e] hover:bg-[#d4b87e] text-[#122926] font-semibold px-10 py-4 rounded-xl transition-colors duration-200 shadow-lg shadow-black/20"
      >
        Contactez-moi
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

</Layout>


<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
