---
import Layout from '../../layouts/Layout.astro';

const expertise = [
  {
    icon: `<svg width="26" height="26" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
      <rect x="9" y="3" width="6" height="4" rx="1"/>
      <path d="m9 12 2 2 4-4"/>
    </svg>`,
    title: "Project Management",
    tags: ["PMP", "PRINCE2", "Agile", "Scrum"],
    description: "Full mastery of international standards and project management methodologies, from scoping to closure.",
  },
  {
    icon: `<svg width="26" height="26" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>`,
    title: "PMO Governance",
    tags: ["Frameworks", "Reporting", "Portfolio"],
    description: "Structuring and managing high-performing project offices aligned with corporate strategy.",
  },
  {
    icon: `<svg width="26" height="26" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73A2 2 0 0 1 10 4a2 2 0 0 1 2-2z"/>
      <circle cx="7.5" cy="14.5" r="1.5" fill="#c9a96e" stroke="none"/>
      <circle cx="16.5" cy="14.5" r="1.5" fill="#c9a96e" stroke="none"/>
    </svg>`,
    title: "Artificial Intelligence",
    tags: ["AI Tools", "Automation", "Agents"],
    description: "Practical AI integration in business: from tool discovery to business process automation.",
  },
  {
    icon: `<svg width="26" height="26" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
      <polyline points="16 7 22 7 22 13"/>
    </svg>`,
    title: "Digital Transformation",
    tags: ["Digitalization", "Change Management"],
    description: "Supporting organizations through their digital transition, from strategy to team adoption.",
  },
];

const pillars = [
  {
    icon: `<svg width="28" height="28" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
    </svg>`,
    title: "Essential Theory",
    description: "The indispensable fundamentals, without the fluff. Every concept is directly anchored in real-world practice.",
  },
  {
    icon: `<svg width="28" height="28" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
    </svg>`,
    title: "Intensive Practice",
    description: "60 to 70% of time dedicated to workshops, concrete exercises and real business case simulations.",
  },
  {
    icon: `<svg width="28" height="28" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 8v4l3 3"/>
    </svg>`,
    title: "Immediate Application",
    description: "Tools, templates and methodologies ready to use from the day after the training.",
  },
];
---

<Layout
  lang="en"
  title="About — Hamza Cherkaoui"
  description="Expert trainer in project management, PMO governance and digital transformation."
>

  <!-- ════════════════════════════════════════
       PAGE HERO
  ════════════════════════════════════════ -->
  <section class="bg-[#1a3a35] text-white pt-16 pb-20 px-6">
    <div class="max-w-3xl mx-auto text-center flex flex-col items-center gap-5">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
        About
      </h1>
      <p class="text-white/70 text-lg leading-relaxed max-w-xl">
        Expert trainer, passionate about performance and technology.
      </p>
      <div class="w-16 h-[3px] rounded-full bg-[#c9a96e] mt-1"></div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       INTRO (photo + bio)
  ════════════════════════════════════════ -->
  <section class="bg-[#f8f8f6] py-20 px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-start gap-12 reveal">

      <div class="flex-shrink-0 mx-auto md:mx-0">
        <div class="relative">
          <div class="absolute -inset-1 rounded-2xl bg-gradient-to-br from-[#c9a96e] to-[#d4b87e] opacity-30 blur-sm"></div>
          <img
            src="/photo-hamza.jpg.JPG"
            alt="Hamza Cherkaoui"
            class="relative w-64 md:w-72 lg:w-80 aspect-[3/4] object-cover object-top rounded-2xl border-4 border-[#c9a96e]/40 shadow-xl"
          />
        </div>
      </div>

      <div class="flex flex-col gap-5 flex-1">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#1a3a35] tracking-tight">Hamza Cherkaoui</h2>
          <p class="text-[#c9a96e] font-medium mt-1 tracking-wide">Tech-driven PMO &amp; Transformation Trainer</p>
        </div>

        <div class="w-10 h-[2px] rounded-full bg-[#c9a96e]/50"></div>

        <p class="text-[#64748B] leading-relaxed">
          As a specialist trainer in project management, PMO governance and digital transformation, I have been supporting companies and professionals for several years in developing their competencies and improving their operational performance.
        </p>
        <p class="text-[#64748B] leading-relaxed">
          My approach is resolutely practical and results-oriented: every training program is designed to be immediately applicable in the field, with concrete tools and proven methodologies.
        </p>
        <p class="text-[#64748B] leading-relaxed">
          Firmly convinced that technology is an essential performance driver, I systematically integrate the latest innovations — particularly AI — into my training programs.
        </p>

        <div class="flex flex-wrap gap-6 pt-2">
          <div class="flex flex-col">
            <span class="text-2xl font-bold text-[#1a3a35]">4</span>
            <span class="text-xs text-[#64748B] font-medium">Areas of expertise</span>
          </div>
          <div class="w-px bg-[#E2E8F0] self-stretch"></div>
          <div class="flex flex-col">
            <span class="text-2xl font-bold text-[#1a3a35]">100%</span>
            <span class="text-xs text-[#64748B] font-medium">Practice-oriented</span>
          </div>
          <div class="w-px bg-[#E2E8F0] self-stretch"></div>
          <div class="flex flex-col">
            <span class="text-2xl font-bold text-[#1a3a35]">2</span>
            <span class="text-xs text-[#64748B] font-medium">Real case studies</span>
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════
       STATS
  ════════════════════════════════════════ -->
  <section class="bg-[#1a3a35] py-16 px-6">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12 reveal">
        <p class="text-[#c9a96e] text-xs font-bold uppercase tracking-[0.25em] mb-3">By the numbers</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white">Expertise that delivers results</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-white/10 rounded-2xl overflow-hidden">
        <div class="reveal bg-[#1a3a35] flex flex-col items-center justify-center gap-2 py-10 px-6 text-center">
          <p class="text-4xl md:text-5xl font-bold text-[#c9a96e]">50+</p>
          <p class="text-sm text-white/70 font-medium leading-snug">Projects delivered</p>
        </div>
        <div class="reveal reveal-delay-1 bg-[#1a3a35] flex flex-col items-center justify-center gap-2 py-10 px-6 text-center">
          <p class="text-4xl md:text-5xl font-bold text-[#c9a96e]">12+</p>
          <p class="text-sm text-white/70 font-medium leading-snug">Years of experience</p>
        </div>
        <div class="reveal reveal-delay-2 bg-[#1a3a35] flex flex-col items-center justify-center gap-2 py-10 px-6 text-center">
          <p class="text-4xl md:text-5xl font-bold text-[#c9a96e]">320+</p>
          <p class="text-sm text-white/70 font-medium leading-snug">Professionals trained</p>
        </div>
        <div class="reveal reveal-delay-3 bg-[#1a3a35] flex flex-col items-center justify-center gap-2 py-10 px-6 text-center">
          <p class="text-4xl md:text-5xl font-bold text-[#c9a96e]">35+</p>
          <p class="text-sm text-white/70 font-medium leading-snug">Missions completed</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       EXPERTISE
  ════════════════════════════════════════ -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-14 reveal">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[#1a3a35] mb-3">
          My Areas of Expertise
        </h2>
        <div class="w-12 h-[2px] rounded-full bg-[#c9a96e] mx-auto mt-4"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {expertise.map((e, i) => (
          <div class={`bg-[#f8f8f6] rounded-2xl border border-[#E2E8F0] p-7 flex flex-col gap-4 card-hover hover:border-[#c9a96e] transition-colors duration-300 reveal${i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : i === 3 ? ' reveal-delay-3' : ''}`}>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-[#c9a96e]/10 flex items-center justify-center flex-shrink-0">
                <Fragment set:html={e.icon} />
              </div>
              <h3 class="text-base font-bold text-[#1a3a35]">{e.title}</h3>
            </div>
            <p class="text-sm text-[#64748B] leading-relaxed">{e.description}</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              {e.tags.map(tag => (
                <span class="text-[11px] font-semibold uppercase tracking-wider px-3 py-1 rounded-full bg-[#c9a96e]/10 text-[#c9a96e]">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════
       METHODOLOGY
  ════════════════════════════════════════ -->
  <section class="bg-[#1a3a35] py-20 px-6">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-14 reveal">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white mb-3">
          My Teaching Approach
        </h2>
        <div class="w-12 h-[2px] rounded-full bg-[#c9a96e] mx-auto mt-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {pillars.map((p, i) => (
          <div class={`relative bg-white/5 border border-white/10 hover:border-[#c9a96e]/50 rounded-2xl p-8 flex flex-col gap-5 transition-colors duration-300 reveal${i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : ''}`}>
            <span class="absolute top-6 right-7 text-5xl font-black text-white/5 select-none leading-none">
              {i + 1}
            </span>
            <div class="w-12 h-12 rounded-xl bg-[#c9a96e]/15 flex items-center justify-center">
              <Fragment set:html={p.icon} />
            </div>
            <div>
              <h3 class="text-base font-bold text-white mb-2">{p.title}</h3>
              <p class="text-sm text-white/60 leading-relaxed">{p.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════
       CONSULTING
  ════════════════════════════════════════ -->
  <section class="bg-[#f8f8f6] py-20 px-6">
    <div class="max-w-5xl mx-auto">

      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-[#1a3a35] mb-3">
          Consulting &amp; Advisory
        </h2>
        <p class="text-[#64748B] max-w-xl mx-auto mt-3">
          In addition to my training programs, I also engage as a strategic advisor on a project basis.
        </p>
        <div class="w-12 h-[2px] rounded-full bg-[#c9a96e] mx-auto mt-5"></div>
      </div>

      <div class="max-w-2xl mx-auto bg-white rounded-2xl border border-[#E2E8F0] hover:border-[#c9a96e] p-8 flex flex-col gap-6 card-hover transition-colors duration-300 reveal">

        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-[#c9a96e]/10 flex items-center justify-center flex-shrink-0">
            <svg width="26" height="26" fill="none" stroke="#c9a96e" stroke-width="1.75" viewBox="0 0 24 24">
              <rect x="2" y="2" width="8" height="8" rx="1"/>
              <rect x="14" y="2" width="8" height="8" rx="1"/>
              <rect x="2" y="14" width="8" height="8" rx="1"/>
              <path d="M14 17h2m2 0h2M18 14v2m0 2v2"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#1a3a35]">CTO Advisory for Startups</h3>
            <p class="text-xs text-[#c9a96e] font-semibold uppercase tracking-widest mt-0.5">Strategic consulting</p>
          </div>
        </div>

        <p class="text-sm text-[#64748B] leading-relaxed">
          Supporting startups in structuring their tech teams and establishing their digital governance framework. From initial audit to strategic recommendations and implementation support.
        </p>

        <div class="border-t border-[#E2E8F0] pt-5 flex flex-col gap-3">
          {["Diagnostic & audit of existing systems", "Personalized strategic recommendations", "Implementation support"].map(point => (
            <div class="flex items-start gap-3 text-sm text-[#64748B]">
              <svg class="flex-shrink-0 mt-0.5" width="15" height="15" fill="none" stroke="#c9a96e" stroke-width="2.5" viewBox="0 0 24 24">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {point}
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       BOTTOM CTA
  ════════════════════════════════════════ -->
  <section class="bg-[#122926] py-20 px-6">
    <div class="max-w-2xl mx-auto text-center flex flex-col items-center gap-6 reveal">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-white leading-snug">
        Let's work together
      </h2>
      <p class="text-white/60 text-lg">
        Contact me to discuss your training or consulting needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://calendly.com/hamzacherkaoui"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#c9a96e] hover:bg-[#d4b87e] text-[#122926] font-semibold px-8 py-4 rounded-xl transition-colors duration-200 shadow-lg shadow-black/20"
        >
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          Book a session
        </a>
        <a
          href="/en/formations"
          class="inline-flex items-center justify-center border border-white/20 hover:border-[#c9a96e] hover:text-[#c9a96e] text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200"
        >
          View training programs
          <svg class="ml-2" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>


<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
