---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    slug: "pmo-portfolio-prioritization-ai",
    image: "/pmo-portfolio-prioritization-ai.png",
    badge: "PMO & AI",
    title: "Reframing Project Portfolio Prioritization",
    excerpt: "Portfolio prioritization has always been one of the most critical PMO responsibilities. AI fundamentally changes the game.",
    readTime: "5 min",
  },
  {
    slug: "ai-everyday-professional",
    image: "/ai-everyday-professional.png",
    badge: "Artificial Intelligence",
    title: "AI for Everyday Professional Use",
    excerpt: "AI is profoundly transforming the way we work. Communication, reports, automation — discover how to integrate it concretely into your daily routine.",
    readTime: "6 min",
  },
];
---

<Layout
  lang="en"
  title="Insights — Hamza Cherkaoui"
  description="Analysis, trends and best practices in project management and AI."
>

  <!-- ════════════════════════════════════════
       PAGE HERO
  ════════════════════════════════════════ -->
  <section class="bg-[#1a3a35] text-white pt-16 pb-20 px-6">
    <div class="max-w-3xl mx-auto text-center flex flex-col items-center gap-5">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight">
        Insights
      </h1>
      <p class="text-white/70 text-lg leading-relaxed max-w-xl">
        Analysis, trends and best practices in project management and AI
      </p>
      <div class="w-16 h-[3px] rounded-full bg-[#c9a96e] mt-1"></div>
    </div>
  </section>


  <!-- ════════════════════════════════════════
       ARTICLES GRID
  ════════════════════════════════════════ -->
  <section class="bg-[#f8f8f6] py-20 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

      {articles.map((article, i) => (
        <a
          href={`/insights/${article.slug}`}
          class={`group bg-white rounded-2xl border border-[#E2E8F0] overflow-hidden card-hover hover:border-[#c9a96e] transition-colors duration-300 flex flex-col reveal${i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : ''}`}
        >
          <div class="w-full h-52 overflow-hidden bg-[#1a3a35]/5">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6 flex flex-col gap-3 flex-1">
            <div class="flex items-center justify-between">
              <span class="text-[11px] font-bold uppercase tracking-widest px-3 py-1 rounded-full text-[#c9a96e] bg-[#c9a96e]/15">
                {article.badge}
              </span>
              <span class="text-xs text-[#64748B] flex items-center gap-1">
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                </svg>
                {article.readTime}
              </span>
            </div>
            <h2 class="text-base font-bold text-[#1a3a35] leading-snug group-hover:text-[#c9a96e] transition-colors duration-200">
              {article.title}
            </h2>
            <p class="text-sm text-[#64748B] leading-relaxed flex-1">
              {article.excerpt}
            </p>
            <div class="pt-3 border-t border-[#E2E8F0] mt-auto">
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#c9a96e] group-hover:gap-2.5 transition-all duration-200">
                Read article
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}

    </div>
  </section>

</Layout>


<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
