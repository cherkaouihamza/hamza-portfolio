---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  lang?: string;
  canonicalUrl?: string;
}

const {
  title = "Hamza Cherkaoui — Formateur Expert en Management de Projet, PMO & IA",
  description = "J'accompagne les entreprises et les professionnels à monter en compétences sur la gestion de projet, la gouvernance PMO et l'intégration de l'IA — avec des formations 100% pratiques et orientées résultats.",
  keywords = "formateur management de projet, formation PMO, formation IA Maroc, chef de projet, gouvernance PMO",
  image = "https://cherkaouihamza.ma/photo-hamza.jpg",
  lang = "fr",
  canonicalUrl,
} = Astro.props;

const isEn = lang === 'en';
const prefix = isEn ? '/en' : '';

// Language switcher URLs (used in navbar + hreflang)
const pathname = Astro.url.pathname;
const frUrl = isEn ? (pathname.replace(/^\/en/, '') || '/') : pathname;
const enUrl = isEn ? pathname : ('/en' + pathname);

const domain = 'https://cherkaouihamza.ma';
const canonical = canonicalUrl ?? (domain + pathname);
const ogLocale = isEn ? 'en_US' : 'fr_FR';
const ogImage = "https://cherkaouihamza.ma/photo-hamza.jpg";
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Hamza Cherkaoui" />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="fr" href={`${domain}${frUrl}`} />
    <link rel="alternate" hreflang="en" href={`${domain}${enUrl}`} />
    <link rel="alternate" hreflang="x-default" href={`${domain}${frUrl}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BJBYS5X9YE"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BJBYS5X9YE');
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-[#0F172A]">

    <!-- ── Navbar ── -->
    <header id="main-nav" class="sticky top-0 z-[100] border-b border-[#c9a96e]/20" style="background-color:#1a3a35;transition:background-color 0.3s ease;">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <!-- Logo image (links to /) -->
        <a href="/" class="flex-shrink-0">
          <img src="/logo-hch.png" alt="Hamza Cherkaoui" class="h-[50px] object-contain" />
        </a>
        <ul class="hidden md:flex items-center gap-8 text-sm font-medium">
          <li><a href={`${prefix}/`} class="nav-link text-white/80">{isEn ? 'Home' : 'Accueil'}</a></li>
          <li><a href={`${prefix}/formations`} class="nav-link text-white/80">{isEn ? 'Training' : 'Formations'}</a></li>
          <li><a href={`${prefix}/case-studies`} class="nav-link text-white/80">Case Studies</a></li>
          <li><a href={`${prefix}/about`} class="nav-link text-white/80">About</a></li>
          <li><a href={`${prefix}/insights`} class="nav-link text-white/80">Insights</a></li>
          <!-- Language switcher (hidden on article pages) -->
          {!pathname.includes('/insights/') && (
          <li class="flex items-center gap-1 border border-white/20 rounded-lg p-0.5">
            <a
              href={frUrl}
              class={`px-2.5 py-1 rounded-md text-xs font-bold transition-all duration-200 ${!isEn ? 'bg-[#c9a96e] text-[#122926]' : 'text-white/50 hover:text-white'}`}
            >FR</a>
            <a
              href={enUrl}
              class={`px-2.5 py-1 rounded-md text-xs font-bold transition-all duration-200 ${isEn ? 'bg-[#c9a96e] text-[#122926]' : 'text-white/50 hover:text-white'}`}
            >EN</a>
          </li>
          )}
          <li>
            <a href={`${prefix}/contact`}
               class="bg-[#c9a96e] hover:bg-[#d4b87e] text-[#122926] font-semibold px-5 py-2 rounded-lg transition-colors duration-200">
              Contact
            </a>
          </li>
        </ul>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-white/80" aria-label="Menu" aria-expanded="false">
          <svg id="icon-open" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </nav>

      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="hidden md:hidden bg-[#1a3a35] border-t border-[#c9a96e]/20 px-6 py-4 flex flex-col gap-4">
        <a href={`${prefix}/`} class="text-white/80 hover:text-white text-sm font-medium py-1">{isEn ? 'Home' : 'Accueil'}</a>
        <a href={`${prefix}/formations`} class="text-white/80 hover:text-white text-sm font-medium py-1">{isEn ? 'Training' : 'Formations'}</a>
        <a href={`${prefix}/case-studies`} class="text-white/80 hover:text-white text-sm font-medium py-1">Case Studies</a>
        <a href={`${prefix}/about`} class="text-white/80 hover:text-white text-sm font-medium py-1">About</a>
        <a href={`${prefix}/insights`} class="text-white/80 hover:text-white text-sm font-medium py-1">Insights</a>
        {!pathname.includes('/insights/') && (
        <div class="flex items-center gap-1 border border-white/20 rounded-lg p-0.5 w-fit">
          <a href={frUrl} class={`px-2.5 py-1 rounded-md text-xs font-bold transition-all duration-200 ${!isEn ? 'bg-[#c9a96e] text-[#122926]' : 'text-white/50 hover:text-white'}`}>FR</a>
          <a href={enUrl} class={`px-2.5 py-1 rounded-md text-xs font-bold transition-all duration-200 ${isEn ? 'bg-[#c9a96e] text-[#122926]' : 'text-white/50 hover:text-white'}`}>EN</a>
        </div>
        )}
        <a href={`${prefix}/contact`} class="bg-[#c9a96e] hover:bg-[#d4b87e] text-[#122926] font-semibold px-5 py-2 rounded-lg transition-colors duration-200 text-sm text-center">
          Contact
        </a>
      </div>
    </header>

    <script>
      const nav = document.getElementById('main-nav');
      function updateNav() {
        if (nav) {
          nav.style.backgroundColor = window.scrollY > 10 ? '#122926' : '#1a3a35';
        }
      }
      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();

      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');
      menuBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden', isOpen);
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
        menuBtn.setAttribute('aria-expanded', String(!isOpen));
      });
    </script>

    <!-- ── Page content ── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ── -->
    <footer class="bg-[#F8FAFC] border-t border-[#E2E8F0]">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-[#64748B]">
        <p class="font-semibold text-[#0F172A]">Hamza Cherkaoui</p>
        <div class="flex flex-col md:flex-row items-center gap-4">
          <a href="mailto:hamzacherkaoui90@gmail.com" class="hover:text-[#c9a96e] transition-colors">
            hamzacherkaoui90@gmail.com
          </a>
          <span class="hidden md:inline text-[#E2E8F0]">|</span>
          <a href="tel:+212676739962" class="hover:text-[#c9a96e] transition-colors">
            +212 676 739 962
          </a>
        </div>
        <p class="text-xs text-[#64748B]">© {new Date().getFullYear()} Hamza Cherkaoui</p>
      </div>
    </footer>

  </body>
</html>

<style>
  html, body { margin: 0; width: 100%; }
</style>
